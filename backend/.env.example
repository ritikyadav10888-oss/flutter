# Server Configuration
PORT=3000

# Database Configuration (PostgreSQL)
# Get this from Neon.tech, Supabase, or any other PG provider
# Example: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=your_postgresql_connection_string

# Authentication
# Generate a secure secret (e.g., using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_secure_jwt_secret

# Rendering Platform (Optional)
# RENDER=true
